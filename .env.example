# Backend
DRIFT_ENV=development
DRIFT_ALLOWED_HOSTS=localhost,127.0.0.1,backend,testserver
DRIFT_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DRIFT_MAX_PAYLOAD_BYTES=10485760
DRIFT_GZIP_MINIMUM_SIZE=1024
DRIFT_ENABLE_HSTS=false
DRIFT_API_KEY=
DRIFT_RATE_LIMIT_PER_MINUTE=180
DRIFT_PORT=8000

# Frontend
VITE_API_BASE_URL=http://localhost:8000
